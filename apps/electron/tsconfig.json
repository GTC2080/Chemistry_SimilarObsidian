{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "jsx": "react-jsx",
    "strict": false,
    "allowJs": true,
    "skipLibCheck": true,
    "types": ["vite/client"]
  },
  "include": [
    "src/renderer-react/**/*",
    "src/smoke-renderer/**/*"
  ]
}
